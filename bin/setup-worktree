#!/usr/bin/env bash
# WorktreeCreate hook — creates a git worktree, writes a settings.local.json
# with pre-approved Bash permissions, then echoes the worktree path to stdout
# so Claude Code knows where the worktree lives.
set -euo pipefail

input=$(cat)

branch=$(echo "$input" | jq -r '.branch // empty')
suggested=$(echo "$input" | jq -r '.worktreePath // empty')

repo_root=$(git rev-parse --show-toplevel)
worktree_base="$repo_root/.claude/worktrees"
mkdir -p "$worktree_base"

# Decide on the worktree path
if [ -n "$suggested" ]; then
  worktree_path="$suggested"
elif [ -n "$branch" ]; then
  slug=$(echo "$branch" | tr '/' '-' | sed 's/[^a-zA-Z0-9._-]/-/g')
  worktree_path="$worktree_base/$slug"
else
  worktree_path="$worktree_base/agent-$(date +%s)"
fi

# Create the worktree if it doesn't already exist
if [ ! -d "$worktree_path" ]; then
  if [ -n "$branch" ]; then
    # Redirect stdout to stderr so git's "HEAD is now at..." line
    # doesn't mix with the path we echo at the end.
    git worktree add "$worktree_path" -b "$branch" HEAD 1>&2 || \
      git worktree add "$worktree_path" "$branch" 1>&2 || \
      git worktree add "$worktree_path" HEAD 1>&2
  else
    git worktree add "$worktree_path" HEAD 1>&2
  fi
fi

# Write pre-approved Bash permissions so agents don't hit permission prompts
claude_dir="$worktree_path/.claude"
mkdir -p "$claude_dir"

cat > "$claude_dir/settings.local.json" <<'JSON'
{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(bundle *)",
      "Bash(chmod *)",
      "Bash(bin/rubocop *)",
      "Bash(bin/rails test *)",
      "Bash(bin/rails test:system *)",
      "Bash(bin/brakeman *)",
      "Bash(bin/bundler-audit)",
      "Bash(bin/ci)"
    ]
  }
}
JSON

# Assign this worktree a parallel-dev slot. Auto-assigned from a shared registry
# and idempotent, so this is safe to run non-interactively (e.g. by an agent).
# The worktree then just runs `bin/dev` to start its Rails server.
echo "Assigning parallel-dev slot for ${worktree_path}..." >&2
(cd "$worktree_path" && ruby bin/use-slot) >&2 || \
  echo "WARNING: bin/use-slot failed — run it manually in the worktree." >&2

# Echo the path — required by the WorktreeCreate hook contract
echo "$worktree_path"
