#!/usr/bin/env bash
set -euo pipefail

# Reset THIS worktree's development databases to a clean, freshly-seeded schema.
#
# How it works: drops and recreates the databases THROUGH the running Postgres
# (SQL), rather than clearing Postgres's data directory.
#
# Why not clear the data directory:
#   On Docker Desktop the Postgres data lives on a hostPath inside the cluster
#   VM. Its filesystem cache (VirtioFS) resurrects "deleted" directory contents
#   the moment a new pod mounts the path — so wiping the dir (from the host OR
#   an in-cluster Job) does NOT give Postgres a clean slate; it comes back up
#   with the old cluster. Dropping/recreating databases via SQL always works
#   because it goes through Postgres, never the host filesystem.
#
# Scope: only this worktree's slot-suffixed databases (chatbot_development[_sN],
# plus _queue/_cable/_cache). Other databases on the shared Postgres (including
# other worktrees' slots) are left untouched.
#
# Prerequisites: the shared dependencies are running so Postgres is reachable on
# localhost — start them with `bin/dev` (or `skaffold run -f skaffold.deps.yaml`).
#
# Corrupt data directory (rare): if Postgres itself won't start ("initdb:
# directory exists but is not empty"), the VirtioFS cache is serving a stale,
# half-initialized dir and no in-cluster delete can fix it reliably. Recover by
# pointing Postgres at a fresh hostPath, e.g.:
#   skaffold delete -f skaffold.deps.yaml
#   # bump charts/postgres/values.yaml storage.hostPath to a new dir, then:
#   bin/dev
# (or restart Docker Desktop to drop the cache).

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

# Load .env (DB creds / overrides) if present.
if [ -f .env ]; then
  set -o allexport
  while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// }" ]] && continue
    export "$line" 2>/dev/null || true
  done < .env
  set +o allexport
fi
export DB_HOST="${DB_HOST:-localhost}" DB_PORT="${DB_PORT:-5432}"
export DB_USERNAME="${DB_USERNAME:-postgres}" DB_PASSWORD="${DB_PASSWORD:-password}"

# Resolve this worktree's slot so the correct (slot-suffixed) databases are reset.
eval "$(ruby bin/use-slot --env)"

# Fail early with a clear message if Postgres isn't reachable.
if ! nc -z -w 3 "$DB_HOST" "$DB_PORT" >/dev/null 2>&1; then
  echo "ERROR: Postgres is not reachable at ${DB_HOST}:${DB_PORT}." >&2
  echo "       Start the shared deps first: bin/dev (or skaffold run -f skaffold.deps.yaml)." >&2
  exit 1
fi

echo "==> Resetting databases for slot ${SLOT:-1} (drop + recreate + load schema + seed)"
bin/rails db:drop db:prepare db:seed

echo ""
echo "Done. This worktree's databases are reset and seeded."
