# Environment configuration for local development.
#
# Parallel worktrees: you do NOT set ports here. `bin/dev` resolves this
# worktree's slot automatically (via bin/use-slot) and runs Rails on a
# per-worktree port against ONE shared set of dependencies. See
# docs/specs/parallel-worktree-shared-deps-plan.md.

# --- Shared dependencies (fixed localhost ports, same for every worktree) ---
# These are exposed by skaffold.deps.yaml as LoadBalancer services.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
# Must match charts/postgres/values.yaml (auth.password).
DB_PASSWORD=password

# Redis (shared)
REDIS_URL=redis://localhost:6379/0

# --- LLM endpoint — any OpenAI-compatible API (Ollama, LM Studio, etc.) ---
OPENAI_API_BASE=http://localhost:11434/v1
LLM_MODEL=llama4

# --- Observability — set OTEL_ENABLED=true to activate tracing. ---
OTEL_ENABLED=false
# When Rails runs locally, this must point at a localhost-reachable OTLP endpoint.
# NOTE: exposing the shared jaeger-collector on localhost:4318 is a follow-up;
# until then leave OTEL_ENABLED=false or port-forward jaeger-collector manually.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=rails-llm-demo

# --- Kubernetes context for the shared deps stack (skaffold). ---
K8S_CONTEXT=docker-desktop
