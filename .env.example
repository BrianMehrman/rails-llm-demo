# Slot configuration — run bin/use-slot N to configure a parallel worktree instance.
# Slot 1 is the default; it uses skaffold.yaml directly and needs no generated files.
SLOT=1

# Explicit port assignments (written by bin/use-slot; base values for slot 1).
# Do not edit these manually — run bin/use-slot N --force to recompute.
RAILS_PORT=3000
GRAFANA_PORT=3001
LOKI_PORT=3100
OTEL_PORT=4318
DB_PORT=5432
REDIS_PORT=6379
PROMETHEUS_PORT=9090
JAEGER_UI_PORT=16686

# Database
DB_HOST=localhost
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis — full URL constructed from REDIS_PORT by bin/use-slot
REDIS_URL=redis://localhost:6379/0

# LLM endpoint — any OpenAI-compatible API (Ollama, LM Studio, etc.)
OPENAI_API_BASE=http://localhost:11434/v1
LLM_MODEL=llama4

# Observability — set OTEL_ENABLED=true to activate tracing.
OTEL_ENABLED=false
# Full URL constructed from OTEL_PORT by bin/use-slot.
# When running outside Kubernetes (bin/rails server), this must point to the
# locally port-forwarded Jaeger endpoint. Inside Kubernetes, the ConfigMap
# provides the in-cluster address automatically.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=rails-llm-demo

# Kubernetes context captured at slot setup time (written by bin/use-slot).
# bin/dev passes this via --kube-context to ensure the stack deploys to the
# correct cluster even if the active context changes later.
K8S_CONTEXT=docker-desktop
