# Database (Skaffold port-forward defaults — Postgres on 5432, Redis on 6379)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM endpoint — any OpenAI-compatible API (Ollama, LM Studio, etc.)
OPENAI_API_BASE=http://localhost:11434/v1
LLM_MODEL=llama4

# Observability — set OTEL_ENABLED=true to activate tracing
OTEL_ENABLED=false
# When running the Rails server outside Kubernetes (bin/rails server), set this to the
# locally port-forwarded Jaeger endpoint. Inside Kubernetes, the ConfigMap provides the
# in-cluster address automatically.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=rails-llm-demo
