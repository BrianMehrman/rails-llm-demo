<div class="page">
  <div class="page-header">
    <h1>Your Chats</h1>
  </div>
  <div class="chat-list" id="chats">
    <% if @chats.empty? %>
      <p style="color: var(--text-muted); text-align: center; padding: 3rem 0;">
        No chats yet. <%= link_to "Start one →", new_chat_path %>
      </p>
    <% else %>
      <% @chats.each do |chat| %>
        <%= render "chat", chat: chat %>
      <% end %>
    <% end %>
  </div>
</div>
